<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EasyCPU.vNext.Views.SospendiWindow"
        Title="Ciclo infinito rilevato"
        Width="360" Height="160"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="16" VerticalAlignment="Center">
        <TextBlock Text="L'esecuzione ha raggiunto il limite di istruzioni configurato."
                   TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Button Content="Continua" Click="OnContinua" MinWidth="85"/>
            <Button Content="Pausa"    Click="OnPausa"    MinWidth="85"/>
            <Button Content="Arresta"  Click="OnArresta"  MinWidth="85" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
