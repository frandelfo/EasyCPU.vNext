<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
             xmlns:vm="clr-namespace:EasyCPU.vNext.ViewModels"
             x:Class="EasyCPU.vNext.Views.MainView"
             x:DataType="vm:MainViewModel">
    <DockPanel>
        <ScrollViewer DockPanel.Dock="Top"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
                <Button Content="File ▼"   Command="{Binding OpenCommand}"    MinWidth="60" MinHeight="44" Padding="8,4"/>
                <Button Content="Compila"  Command="{Binding CompileCommand}" MinWidth="60" MinHeight="44" Padding="8,4"/>
                <Button Content="Avvia"    Command="{Binding RunCommand}"     MinWidth="60" MinHeight="44" Padding="8,4"/>
                <Button Content="Ferma"    Command="{Binding StopCommand}"    MinWidth="60" MinHeight="44" Padding="8,4"/>
                <Button Content="→ Into"   Command="{Binding StepIntoCommand}" MinWidth="60" MinHeight="44" Padding="8,4"/>
                <Button Content="→→ Over"  Command="{Binding StepOverCommand}" MinWidth="60" MinHeight="44" Padding="8,4"/>
                <Button Content="↑ Out"    Command="{Binding StepOutCommand}"  MinWidth="60" MinHeight="44" Padding="8,4"/>
            </StackPanel>
        </ScrollViewer>
        <controls:DockControl Layout="{Binding Layout}" Factory="{Binding DockFactory}" />
    </DockPanel>
</UserControl>
